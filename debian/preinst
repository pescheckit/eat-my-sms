#!/bin/sh
# preinst script for eat-my-sms
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <new-preinst> `install'
#        * <new-preinst> `install' <old-version>
#        * <new-preinst> `upgrade' <old-version>
#        * <old-preinst> `abort-upgrade' <new-version>
# for details, see https://www.debian.org/doc/debian-policy/ or
# the debian-policy package


case "$1" in
    install|upgrade)
        # Migrate from broken 1.1.5 packaging where these paths were created
        # as directories (with the source file nested inside) instead of as
        # regular files. Without this cleanup, dpkg refuses the upgrade with
        # "trying to overwrite directory with non-directory".
        if [ -d /usr/bin/eat-my-sms-start-all ]; then
            rm -rf /usr/bin/eat-my-sms-start-all
        fi
        if [ -d /etc/eat-my-sms/devices.conf ]; then
            rm -rf /etc/eat-my-sms/devices.conf
        fi
    ;;

    abort-upgrade)
    ;;

    *)
        echo "preinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
